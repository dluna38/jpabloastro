---
import SectionTitle from './SectionTitle.astro';
import PostCard from './PostCard.astro';
import { sanityClient } from '../lib/sanity'; // O tu configuración de cliente Sanity
import type { Publicacion as Post } from '../../types/sanity';

// 1. Fetch de datos directo en el servidor
const postsQuery = `*[
    _type == "publicacion"
    && defined(slug.current)
  ]|order(fechaPublicacion desc)[0...3]{titulo, slug, fechaPublicacion, imagen, extracto}`;

let posts: any[] = [];

try {
  posts = await sanityClient.fetch(postsQuery);
} catch (error) {
  console.error("Error cargando posts:", error);
}

const hasPosts = posts && posts.length > 0;
---

<section class="post-section">
  <div class="container">
    <SectionTitle title="Últimas Publicaciones" align="left" />

    {hasPosts ? (
      <div class="posts-grid">
        {posts.map((post:Post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="no-posts">
        <p>Próximamente publicaremos noticias y actualizaciones.</p>
      </div>
    )}

    {hasPosts && (
      <div class="center-btn">
        <a href="/blog" class="btn btn-secondary">Ver Todas las Noticias</a>
      </div>
    )}
  </div>
</section>

<style>
  .post-section {
    padding: 2rem 1rem;
    background-color: var(--color-white);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .center-btn {
    text-align: center;
  }

  .no-posts {
    text-align: center;
    padding: 3rem;
    color: var(--color-secondary);
    font-style: italic;
    font-size: 1.1rem;
  }

  @media (max-width: 1100px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>