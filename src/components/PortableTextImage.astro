---
import Image from 'astro/components/Image.astro';
import { imageUrlFor } from '../lib/imageUrlFor'; // Asegúrate de tener configurado tu builder de imágenes

const { node } = Astro.props;
// 'node' contiene la imagen, el 'alt' y nuestro nuevo 'caption'
---

<figure>
  <Image 
    src={imageUrlFor(node).url()} 
    alt={node.alt || ""}
    loading="lazy" inferSize
  />
  {node.caption && (
    <figcaption >
      {node.caption}
    </figcaption>
  )}
</figure>


<style>
    figure {
        text-align: left;
    }
    
    figcaption {
        font-style: italic;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        color: #666;
    }
</style>