---
import { Image } from 'astro:assets';
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  title: string;
  slug: string;
  imageUrl?: string;
  location?: string;
}

const { title, slug, imageUrl, location } = Astro.props;
---

<div class="project-card">
  <div class="image-wrapper">
    {imageUrl ? (
      <Image src={imageUrl} alt={title} class="project-image" loading="lazy" width={360} height={250}/>
    ) : (
      <ImagePlaceholder />
    )}
    <div class="overlay">
      <a href={`/proyectos/${slug}`} class="view-btn">Ver Proyecto</a>
    </div>
  </div>
  <div class="card-content">
    <div class="project-meta">
      {location && (
        <span class="location">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          {location}
        </span>
      )}
    </div>
    <h3 class="project-title">{title}</h3>
    <a href={`/proyectos/${slug}`} class="details-link">Más detalles</a>
  </div>
</div>

<style>
.project-card {
  background-color: var(--card-bg, var(--color-white));
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  max-width: 360px;
  width: 100%;
  margin: 0 auto;
}

.project-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
}

.image-wrapper {
  position: relative;
  height: 250px;
  overflow: hidden;
  background-color: var(--color-gray-200);
}

.project-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.project-card:hover .project-image {
  transform: scale(1.05);
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(43, 61, 65, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.project-card:hover .overlay {
  opacity: 1;
}

.view-btn {
  background-color: var(--color-white);
  color: var(--color-primary);
  padding: 0.75rem 1.5rem;
  border-radius: 4px;
  font-weight: 600;
  text-decoration: none;
  transform: translateY(20px);
  transition: transform 0.3s ease;
}

.project-card:hover .view-btn {
  transform: translateY(0);
}

.card-content {
  padding: 1.5rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.project-meta {
  display: flex;
  margin-bottom: 0.5rem;
}

.location {
  display: flex;
  align-items: center;
  font-size: 0.85rem;
  color: var(--card-meta-color, var(--color-secondary));
  gap: 0.25rem;
}

.project-title {
  font-size: 1.25rem;
  margin-bottom: 0.5rem;
  color: var(--card-title-color, var(--color-primary));
}

.details-link {
  font-size: 0.9rem;
  color: var(--color-accent);
  font-weight: 500;
  margin-top: auto;
  text-decoration: none;
}

.details-link:hover {
  text-decoration: underline;
}
</style>