---
const { titulo, descripcion, icon: Icon,iconSize } = Astro.props;
---

<div class="valor-card">
    <div class="valor-header">
        <div class="icon-wrapper">
            <span class="icon"><Icon size={iconSize || 24} /></span>
        </div>
        <h3>{titulo}</h3>
    </div>
    <p>{descripcion}</p>
</div>


<style>
    .valor-header {
    display: flex;
    align-items: center; /* Centrado vertical */
    gap: 1rem; /* Espacio generoso entre icono y texto */
    margin-bottom: 1.2rem;
  }
  .valor-card {
    background: transparent;
    border: 1px solid #e9dcc9; /* Color de borde sutil */
    border-radius: 16px;
    padding: 2rem;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .valor-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #666;
    margin-left: 0.5rem; /* Un pequeño sangrado opcional para dar aire */
  }
  .valor-card h3 {
    font-size: 1.25rem;
    color: #333;
    font-weight: 700;
    margin: 0; /* Quitamos el margen para que alinee perfecto con el icono */
    line-height: 1.2;
  }
  .valor-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    background: #ffffff;
  }

  .icon-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    font-size: 1.4rem;
    color: #d97767;
    /* Un fondo sutil circular ayuda a que no se vea pegado */
    background-color: rgba(217, 119, 103, 0.1);
    width: 45px;
    height: 45px;
    border-radius: 50%;
    flex-shrink: 0; /* Evita que el icono se aplaste */
  }
  .valor-card:last-child:nth-child(7) {
    grid-column: 1 / -1; /* Ocupa todas las columnas */
    max-width: 600px; /* Opcional: para que no se estire demasiado el texto */
    justify-self: center;
  }
</style>
