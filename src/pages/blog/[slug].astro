---
export const prerender = true;

import Image from 'astro/components/Image.astro';
import type { Publicacion } from '../../../types/sanity';
import BaseLayout, { type SEOProps } from '../../layouts/BaseLayout.astro';
import formatDateCustom from '../../lib/formatDateCustom';
import { sanityClient, imageUrlFor } from '../../lib/sanity';
import { PortableText } from "astro-portabletext";
import PortableTextImage from '../../components/PortableTextImage.astro';

export async function getStaticPaths() {

  const query = `*[_type == "publicacion"] {
  _id,
  titulo,
  contenido,
  slug,
  fechaPublicacion,
  imagen,
  extracto
}`;
  
  const posts = await sanityClient.fetch(query);
   if (!posts) {
    console.warn("No se encontraron publicaciones para generar rutas.");
    return [];
  }

  return posts.map((post: Publicacion) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}


