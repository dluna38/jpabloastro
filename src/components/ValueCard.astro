---
// src/components/ValueCard.astro

interface ValueItem {
  title: string;
  description: string;
  icon?: string; // Permite pasar un icono personalizado (texto, emoji o SVG en string). Por defecto será '✓'
}

interface Props {
  layout?: 'horizontal' | 'vertical';
  label: string;
  title: string;
  description: string;
  items: ValueItem[];
}

const { 
  layout = 'horizontal', 
  label, 
  title, 
  description, 
  items 
} = Astro.props;
---

<section class={`container value-section ${layout}`}>
  <div class="value-card">
    <div class="value-left">
        
      <span class="value-label">{label}</span>
      <h2 class="value-title">{title}</h2>
      <p class="value-text">{description}</p>
    </div>

    <div class="value-right">
      {items.map((item) => (
        <div class="value-item">
          <div class="icon" set:html={item.icon || '&#10003;'} />
          <div class="item-content">
            <h4>{item.title}</h4>
            <p>{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .value-section {
    padding: 0 20px;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .value-card {
    background-color: var(--color-white, #ffffff);
    border-radius: 10px;
    padding: 60px;
    max-width: 1200px;
    width: 100%;
    display: flex;
    gap: 60px;
    border: 1px solid var(--color-neutral, #e5e5e5);
  }

  .horizontal .value-card {
    flex-direction: row;
  }
  
  .vertical .value-card {
    flex-direction: column;
    max-width: 800px; 
    gap: 40px;
  }

  @media (max-width: 768px) {
    .value-card {
      flex-direction: column !important;
      padding: 30px 20px;
      gap: 30px;
    }
  }

  .value-left {
    flex: 1;
  }

  .value-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .value-label {
    font-family: var(--font-body, sans-serif);
    font-size: 0.85rem;
    letter-spacing: 2px;
    font-weight: 600;
    color: var(--color-steel-gray, #666);
    text-transform: uppercase;
  }

  .value-title {
    font-family: var(--font-heading, sans-serif);
    font-size: 2rem;
    margin: 15px 0 20px;
    color: var(--color-primary, #1a1a1a);
  }

  .value-text {
    font-family: var(--font-body, sans-serif);
    color: var(--color-secondary, #4a4a4a);
    line-height: 1.6;
  }

  .value-item {
    display: flex;
    gap: 15px;
    align-items: flex-start;
  }

  .item-content h4 {
    margin: 0;
    font-family: var(--font-heading, sans-serif);
    font-size: 1rem;
    color: var(--color-primary, #1a1a1a);
  }

  .item-content p {
    margin: 5px 0 0;
    font-family: var(--font-body, sans-serif);
    font-size: 0.95rem;
    color: var(--color-secondary, #4a4a4a);
    line-height: 1.5;
  }

  .icon {
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--color-accent, #0056b3);
    color: var(--color-white, #ffffff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: bold;
  }
</style>