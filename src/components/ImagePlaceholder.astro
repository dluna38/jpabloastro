---
// ImagePlaceholder.astro
interface Props {
    bgColor?: string;
    logoSize?: string;
    logoOpacity?: number;
}

const {
    bgColor = 'var(--color-light)',
    logoSize = '60%',
    logoOpacity = 0.15
} = Astro.props;
---

<div class="image-placeholder" style={{ backgroundColor: bgColor }}>
    <img 
        src="/logo_clean_opti.webp" 
        alt="Placeholder" 
        class="placeholder-logo" 
    />
</div>

<style define:vars={{ logoSize, logoOpacity }}>
    /* Astro permite pasar variables directamente al CSS con define:vars */
    .image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .placeholder-logo {
        width: var(--logoSize);
        max-width: 180px;
        height: auto;
        opacity: var(--logoOpacity);
        object-fit: contain;
        user-select: none;
        pointer-events: none;
        filter: grayscale(100%);
    }
</style>