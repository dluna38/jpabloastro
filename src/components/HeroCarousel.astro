---
import { Image } from 'astro:assets';
import casa1 from '../assets/photo-casa.webp';
import sanCarlos from '../assets/photo-sancarlos.webp';
import comparacion from '../assets/photo_comparacion_remodelacion.webp';
const slides = [
  {
    id: 1,
    title: 'Construyendo sueños, transformando regiones',
    subtitle: 'Calidad, innovación y sostenibilidad en cada proyecto.',
    image: sanCarlos,
    link: '/contacto',
    buttonText: 'Contáctanos'
  },
  {
    id: 2,
    title: 'Expertos en Obra Civil y Remodelaciones',
    subtitle: 'Transformamos espacios para mejorar tu calidad de vida.',
    image: comparacion,
    link: '/servicios',
    buttonText: 'Nuestros Servicios'
  },
  {
    id: 3,
    title: 'Diseño Arquitectónico a tu Medida',
    subtitle: 'Hacemos realidad la casa de tus sueños.',
    image: casa1,
    link: '/proyectos',
    buttonText: 'Ver Proyectos'
  }
];
---

<div class="hero-carousel" id="hero-carousel">
  <div class="carousel-inner">
    {slides.map((slide, index) => (
      <div 
        class={`slide ${index === 0 ? 'active' : ''}`}
        data-index={index}
      >
        <Image 
          src={slide.image} 
          alt={slide.title}
          loading={index === 0 ? "eager" : "lazy"}
          fetchpriority={index === 0 ? "high" : "low"}
          class="slide-bg-img"
        />
        <div class="container slide-content">
          <h2 class="slide-title" aria-label={slide.title}>{slide.title}</h2>
          <p class="slide-subtitle">{slide.subtitle}</p>
          <a href={slide.link} class="btn btn-primary" aria-label={slide.buttonText} role="button">{slide.buttonText}</a>
        </div>
      </div>
    ))}
  </div>

  <div class="carousel-controls">
    {slides.map((_, index) => (
      <button 
        class={`control-dot ${index === 0 ? 'active' : ''}`}
        data-go={index}
        aria-label={`Ir a diapositiva ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  const initHero = () => {
    const carousel = document.querySelector('#hero-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('.slide');
    const dots = carousel.querySelectorAll('.control-dot');
    let current = 0;
    let interval: any;

    const changeSlide = (nextIndex: number) => {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      
      current = nextIndex;
      
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    };

    const autoPlay = () => {
      const next = (current + 1) % slides.length;
      changeSlide(next);
    };

    // Eventos de los puntos (dots)
    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        clearInterval(interval);
        changeSlide(idx);
        startInterval();
      });
    });

    const startInterval = () => {
      interval = setInterval(autoPlay, 5000);
    };

    startInterval();
  };

  // Inicialización compatible con ViewTransitions
  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>

<style>
.hero-carousel {
  position: relative;
  height: 80vh;
  min-height: 500px;
  overflow: hidden;
  background-color: var(--color-primary);
}

.carousel-inner {
  height: 100%;
  width: 100%;
}

.slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: none;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 1s ease, visibility 1s;
  z-index: 1;
}
.slide-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -1; 
}
.slide::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(rgba(43, 61, 65, 0.6), rgba(43, 61, 65, 0.6));
  z-index: 0;
}

.slide.active {
  opacity: 1;
  visibility: visible;
  z-index: 2;
}

.slide-content {
  position: relative;
  text-align: center;
  color: white;
  max-width: 800px;
  padding: 0 1rem;
  z-index: 1;
}

.slide-title {
  font-size: 3.5rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  color: var(--color-white);
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.slide-subtitle {
  font-size: 1.25rem;
  margin-bottom: 2rem;
  opacity: 0.9;
}

.carousel-controls {
  position: absolute;
  bottom: 2rem;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 1rem;
  z-index: 10;
  min-height: 12px;
}

.control-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.5);
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.control-dot.active {
  background-color: var(--color-accent);
  transform: scale(1.2);
}

@media (max-width: 768px) {
  .slide-title {
    font-size: 2.2rem;
  }
}
</style>