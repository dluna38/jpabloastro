---
// Importa tus componentes
import SectionTitle from "../components/SectionTitle.astro";
// Asumiendo que tienes estos íconos como componentes en Astro
import IconFacebook from "../components/icon/IconFacebook.astro";
import IconInstagram from "../components/icon/IconInstagram.astro";
import IconWhatsApp from "../components/icon/IconWhatsApp.astro";
import IconYoutube from "../components/icon/IconYoutube.astro";
import BaseLayout, { type SEOProps } from "../layouts/BaseLayout.astro";
import { myCompanyInfo } from "../lib/dataCompany";


const pageTitle = "Contacto | Construcciones Juan Pablo II";
const pageDescription =
  "Contáctanos para tus proyectos de construcción y remodelación en San Carlos, Antioquia. Cotiza hoy mismo.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: pageTitle,
  description: pageDescription,
  image: myCompanyInfo.logo,
  about: myCompanyInfo.description[0],
  url: Astro.url.href,
  sameAs: [
    myCompanyInfo.socials.instagram?.url,
    myCompanyInfo.socials.facebook?.url,
    myCompanyInfo.socials.whatsapp?.url,
    myCompanyInfo.socials.youtube?.url,
  ],
};  

const customSEO: SEOProps = {
  title: pageTitle,
  description: pageDescription,
  url: Astro.url.href,
};
---

<BaseLayout title={pageTitle} description={pageDescription} seo={customSEO} schema={schema}>
  <div class="contact-page">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">Contáctanos</h1>
        <p class="page-subtitle">
          Estamos listos para hacer realidad tu proyecto en el Oriente
          Antioqueño.
        </p>
      </div>
    </div>

    <section class="container content-section">
      <div class="contact-grid">
        <div class="contact-info">
          <SectionTitle title="Información de Contacto" align="left" />
          <p class="info-text">
            Visítanos en nuestra sede principal o comunícate con nosotros a
            través de nuestros canales digitales.
          </p>

          <ul class="info-list">
            <li>
              <span class="icon">📍</span>
              <div>
                <strong>Dirección:</strong><br />
                {myCompanyInfo.address}
              </div>
            </li>
            <li>
              <span class="icon">📞</span>
              <div>
                <strong>Teléfono:</strong><br />
                <a href="tel:+573001234567">{myCompanyInfo.phone}</a>
              </div>
            </li>
            <li>
              <span class="icon">✉️</span>
              <div>
                <strong>Email:</strong><br />
                <span id="email"></span>
              </div>
            </li>
            <li>
              <span class="icon">⏰</span>
              <div>
                <strong>Horario de Atención:</strong><br />
                Lunes a Viernes: 8:00 AM - 6:00 PM<br />
                Sábados: 8:00 AM - 1:00 PM
              </div>
            </li>
          </ul>

          <div class="social-links">
            <SectionTitle
              title="Síguenos en nuestras redes sociales"
              align="left"
              as="h3"
              fontSize="1.5rem"
            />
            <div class="social-icons">
              <a
                href={myCompanyInfo.socials.whatsapp?.url}
                aria-label="WhatsApp"
                target="_blank"
                rel="noopener noreferrer"
                role="button"
              >
                <IconWhatsApp size={24} />
                WhatsApp
              </a>
              <a
                href={myCompanyInfo.socials.facebook?.url}
                aria-label="Facebook"
                target="_blank"
                rel="noopener noreferrer"
                role="button"
              >
                <IconFacebook size={24} />
                Facebook
              </a>
              <a
                href={myCompanyInfo.socials.instagram?.url}
                aria-label="Instagram"
                target="_blank"
                rel="noopener noreferrer"
                role="button"
              >
                <IconInstagram size={24} />
                Instagram
              </a>
              <a
                href={myCompanyInfo.socials.youtube?.url}
                aria-label="YouTube"
                target="_blank"
                rel="noopener noreferrer"
                role="button"
              >
                <IconYoutube size={25} />
                YouTube
              </a>
            </div>
          </div>
        </div>

        <div class="contact-form-wrapper">
          <div class="contact-form-title">
            <IconWhatsApp size={42} />
            <SectionTitle title="Escríbenos al WhatsApp" align="left" />
          </div>

          <form id="whatsapp-form" class="contact-form" autocomplete="on">
            <div class="form-group">
              <label for="name">Nombre Completo</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Tu nombre"
              />
            </div>

            <div class="form-group">
              <label for="email">Correo Electrónico</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tucorreo@ejemplo.com"
              />
            </div>

            <div class="form-group">
              <label for="phone">Teléfono</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+57 300..."
                required
              />
            </div>

            <div class="form-group">
              <label for="service">Servicio de Interés</label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Selecciona una opción</option
                >
                <option value="obra-civil">Obra Civil</option>
                <option value="remodelacion">Remodelación</option>
                <option value="diseno">Diseño Arquitectónico</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Mensaje</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Cuéntanos sobre tu proyecto..."></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="btn btn-primary full-width"
            >
              Enviar Mensaje
            </button>

            <p id="success-msg" class="success-msg" style="display: none;">
              ¡Mensaje enviado con éxito! Te contactaremos pronto.
            </p>
            <p id="error-msg" class="error-msg" style="display: none;">
              Hubo un error al preparar el mensaje. Inténtalo de nuevo.
            </p>
          </form>
        </div>
      </div>
    </section>

    <section class="map-section">
      <div class="container">
        <SectionTitle title="Encuéntranos en" />
        <iframe
          title="Mapa mostrado la ubicación de la sede de Construcciones Juan Pablo II"
          src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d991.6428084352909!2d-74.99529673044468!3d6.188087332903483!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNsKwMTEnMTcuMSJOIDc0wrA1OSc0MC44Ilc!5e0!3m2!1ses!2sco!4v1771522267807!5m2!1ses!2sco"
          width="100%"
          height="350"
          style="border:0; border-radius: 8px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const user = "informacion";
  const domain = "juanpabloll.com";
  const emailElement = document.getElementById("email");
  if (emailElement) {
    emailElement.innerHTML = `<a href="mailto:${user}@${domain}">${user}@${domain}</a>`;
  }

  const form = document.getElementById("whatsapp-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successMsg = document.getElementById("success-msg");
  const errorMsg = document.getElementById("error-msg");

  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();

      // Resetear estados visuales
      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";
      if (successMsg) successMsg.style.display = "none";
      if (errorMsg) errorMsg.style.display = "none";

      try {
        const formData = new FormData(form);
        const name = formData.get("name") as string;
        const email = formData.get("email") as string;
        const phone = formData.get("phone") as string;
        const serviceValue = formData.get("service") as string;
        const messageText = formData.get("message") as string;

        const serviceMap: Record<string, string> = {
          "obra-civil": "Obra Civil",
          remodelacion: "Remodelación",
          diseno: "Diseño Arquitectónico",
          otro: "Otro",
        };

        const serviceText = serviceValue
          ? serviceMap[serviceValue]
          : "No especificado";

        const whatsappMessage =
          `¡Hola! Vengo desde la página web:\n\n` +
          `*Nombre:* ${name}\n` +
          `*Correo:* ${email}\n` +
          `*Teléfono:* ${phone}\n` +
          `*Servicio de Interés:* ${serviceText}\n` +
          `*Mensaje:* ${messageText}`;

        const encodedMessage = encodeURIComponent(whatsappMessage);
        // Número de WhatsApp configurado (Asegúrate de cambiarlo si es necesario)
        const whatsappNumber = "573011234567";

        window.open(
          `https://wa.me/${whatsappNumber}?text=${encodedMessage}`,
          "_blank",
        );

        if (successMsg) successMsg.style.display = "block";
        form.reset();
      } catch (error) {
        console.error("Error al abrir WhatsApp:", error);
        if (errorMsg) errorMsg.style.display = "block";
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar Mensaje";
      }
    });
  }
</script>

<style>
  .contact-form-title {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .social-icons {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    max-width: 400px;
    gap: 1rem;
  }
  .social-icons a {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.5rem;
  }

  .page-header {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-white);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-light);
  }

  .content-section {
    padding: 5rem 1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .contact-info h2,
  .contact-form-wrapper h2 {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .info-text {
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  .info-list {
    list-style: none;
    margin-bottom: 3rem;
    padding-left: 0;
  }

  .info-list li {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: flex-start;
  }

  .icon {
    font-size: 1.5rem;
  }

  .info-list a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .info-list a:hover {
    text-decoration: underline;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .full-width {
    width: 100%;
    border: none;
    font-size: 1rem;
    cursor: pointer;
  }

  .success-msg {
    color: green;
    margin-top: 1rem;
    text-align: center;
    font-weight: 500;
  }

  .error-msg {
    color: red;
    margin-top: 1rem;
    text-align: center;
    font-weight: 500;
  }

  .map-section {
    padding: 0 1rem 3rem;
    background-color: var(--color-white);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
