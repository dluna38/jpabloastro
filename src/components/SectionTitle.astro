---
interface Props {
  title: string;
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'div' | 'p';
  align?: 'left' | 'center' | 'right';
  color?: string;
  fontSize?: string;
  margin?: string; // Nueva propiedad para el margen
  extraClasses?: string;
}

const { 
  title, 
  as: Tag = 'h2',
  align = 'center', 
  color = 'var(--color-primary)', 
  fontSize = '2rem',
  margin, // Recibimos el margen
  extraClasses = '' 
} = Astro.props;

const alignClass = align;
---

<Tag 
  class={`section-title ${alignClass} ${extraClasses}`} 
  style={{ color, fontSize, margin }}
>
  {title}
</Tag>

<style>
  .section-title {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: var(--color-primary);
    position: relative;
    display: block;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background-color: var(--color-accent);
    margin-top: 0.5rem;
  }
  
  .center { text-align: center; }
  .center::after { margin-left: auto; margin-right: auto; }

  .left { text-align: left; }
  .left::after { margin-left: 0; margin-right: auto; }

  .right { text-align: right; }
  .right::after { margin-left: auto; margin-right: 0; }
</style>