---
import IconArchitec from "../components/icon/IconArchitec.astro";
import IconPaintRoller from "../components/icon/IconPaintRoller.astro";
import IconWall from "../components/icon/IconWall.astro";
import SectionTitle from "../components/SectionTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Servicios | Construcciones Juan Pablo II";
const description =
  "Ofrecemos servicios de Obra Civil, Mejora de viviendas y Remodelaciones, Diseño Arquitectónico en San Carlos y el Oriente Antioqueño.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Obra Civil",
    description: "Ejecutamos proyectos de construcción civil desde cero con los más altos estándares de calidad, incluyendo viviendas, edificaciones comerciales e infraestructura.",
    provider: {
      "@id": `${Astro.site}#organization`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Mejoramiento de Vivienda y Remodelación",
    description: "Transformamos espacios existentes combinando funcionalidad y estética, abarcando ampliaciones, modernización de cocinas, baños y reparaciones estructurales.",
    provider: {
      "@id": `${Astro.site}#organization`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Diseño Arquitectónico",
    description: "Creamos diseños de planos, renders 3D, tramitación de licencias y diseño adaptado al clima del Oriente Antioqueño acompañando todo el proceso creativo.",
    provider: {
      "@id": `${Astro.site}#organization`
    }
  }
];

const customSEO = {
  title: title,
  description: description,
  keywords: "construcción, obra civil, diseño arquitectónico, remodelación, San Carlos, Oriente Antioqueño",
};
---

<BaseLayout title={title} seo={customSEO} schema={schema}>
  <div class="services-page">
    <div class="page-header">
      <div class="container">
        <SectionTitle
          title="Nuestros Servicios"
          align="center"
          as="h1"
          color="var(--color-white)"
        />
        <p class="page-subtitle">
          Ofrecemos servicios de construcción y diseño adaptados a tus
          necesidades, cuidando cada detalle desde la planificación hasta la
          entrega final.
        </p>
      </div>
    </div>

    <section id="obra-civil" class="service-detail">
      <div class="container">
        <div class="service-detail-inner">
          <div class="service-icon-col">
            <div class="icon-circle">
              <IconWall size={48} />
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle title="Obra Civil" align="left" />
            <p class="service-lead">
              Ejecutamos proyectos de construcción desde cero con los más altos
              estándares de calidad.
              <strong class="highlight-text"
                >Trae tus planos o usa uno de los nuestros</strong
              > — nos adaptamos a tu visión y presupuesto.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Construcción de viviendas unifamiliares
                y multifamiliares
              </li>
              <li>
                <span class="feature-icon">✓</span> Edificaciones comerciales e institucionales
              </li>
              <li>
                <span class="feature-icon">✓</span> Cimentaciones, estructuras y acabados
                completos
              </li>
              <li>
                <span class="feature-icon">✓</span> Cumplimiento de normativa sismorresistente
                (NSR-10)
              </li>
              <li>
                <span class="feature-icon">✓</span> Obras de infraestructura vial
                y urbanística
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="remodelacion" class="service-detail alt-bg">
      <div class="container">
        <div class="service-detail-inner reverse">
          <div class="service-icon-col">
            <div class="icon-circle">
              <IconPaintRoller size={48} />
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle
              title="Mejoramiento de Vivienda y Remodelación"
              align="left"
            />
            <p class="service-lead">
              Transformamos espacios existentes para adaptarlos a tus nuevas
              necesidades y estilo de vida. Dale nueva vida a tu hogar con
              remodelaciones que combinan funcionalidad y estética moderna.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Ampliaciones y mejoramiento de
                espacios existentes
              </li>
              <li>
                <span class="feature-icon">✓</span> Modernización de cocinas, baños
                y fachadas
              </li>
              <li>
                <span class="feature-icon">✓</span> Reparaciones estructurales y reforzamiento
              </li>
              <li>
                <span class="feature-icon">✓</span> Acabados en pisos, pintura y enchapes
              </li>
              <li>
                <span class="feature-icon">✓</span> Asesoría personalizada para transformar
                tu hogar
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="diseno-arquitectonico" class="service-detail">
      <div class="container">
        <div class="service-detail-inner">
          <div class="service-icon-col">
            <div class="icon-circle">
              <IconArchitec size={48} />
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle title="Diseño Arquitectónico" align="left" />
            <p class="service-lead">
              Creamos espacios funcionales y estéticamente atractivos, adaptados
              al entorno y a tus necesidades. Desde la idea inicial hasta los
              planos definitivos, te acompañamos en todo el proceso creativo.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Diseño de planos arquitectónicos
                y estructurales
              </li>
              <li>
                <span class="feature-icon">✓</span> Renders 3D y visualización de
                proyectos
              </li>
              <li>
                <span class="feature-icon">✓</span> Tramitación de licencias de construcción
              </li>
              <li>
                <span class="feature-icon">✓</span> Diseño adaptado al clima del Oriente
                Antioqueño
              </li>
              <li>
                <span class="feature-icon">✓</span> Optimización de espacios y distribución
                funcional
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container">
        <h2 class="cta-text">¿Tienes un proyecto en mente? Hablemos.</h2>
        <a href="/contacto" class="btn btn-primary btn-large"
          >Solicita tu Cotización</a
        >
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }
  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-white);
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-light);
  }

  .service-detail {
    padding: 3rem 1rem;
    scroll-margin-top: 80px;
  }
  .service-detail.alt-bg {
    background-color: var(--color-background);
  }
  .service-detail-inner {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
  }
  .service-detail-inner.reverse {
    flex-direction: row-reverse;
  }

  .icon-circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background-color: var(--color-light);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .service-detail:hover .icon-circle {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .service-lead {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-secondary);
    margin-bottom: 2rem;
  }
  .highlight-text {
    color: var(--color-accent);
    font-weight: 700;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    line-height: 1.6;
  }
  .feature-icon {
    color: var(--color-accent);
    font-weight: 700;
    margin-top: 2px;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight bold;
  }


  .cta-banner {
    padding: 5rem 1rem;
    background-color: var(--color-accent);
    text-align: center;
    color: var(--color-white);
  }
  .cta-text {
    font-size: 2rem;
    margin-bottom: 2rem;
    max-width: 700px;
    margin: 0 auto 2rem;
    color: var(--color-white);
  }

  .btn-large {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    border-radius: 50px;
    background-color: var(--color-white);
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 700;
    border: 2px solid var(--color-white);
  }
  .btn-large:hover {
    background-color: transparent;
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .service-detail-inner,
    .service-detail-inner.reverse {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .feature-list li {
      width: 100%;
      justify-content: flex-start !important; 
      text-align: left; 
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .cta-text {
      font-size: 1.5rem;
    }
  }
</style>
