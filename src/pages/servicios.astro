---
import IconWall from "../components/icon/IconWall.astro";
import SectionTitle from "../components/SectionTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Servicios | Construcciones Juan Pablo II";
const description =
  "Ofrecemos servicios de Obra Civil, Mejora de viviendas y Remodelaciones, Diseño Arquitectónico en San Carlos y el Oriente Antioqueño.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  description:
    "Obra Civil, Mejora de viviendas y Remodelaciones, Diseño Arquitectónico",
  provider: {
    "@type": "HomeAndConstructionBusiness",
    name: "Construcciones Juan Pablo II S.A.S.",
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="services-page">
    <div class="page-header">
      <div class="container">
        <SectionTitle
          title="Nuestros Servicios"
          align="center"
          as="h1"
          color="var(--color-white)"
        />
        <p class="page-subtitle">
          Ofrecemos servicios de construcción y diseño adaptados a tus
          necesidades, cuidando cada detalle desde la planificación hasta la
          entrega final.
        </p>
      </div>
    </div>

    <section id="obra-civil" class="service-detail">
      <div class="container">
        <div class="service-detail-inner">
          <div class="service-icon-col">
            <div class="icon-circle">
              <IconWall size={48} />
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle title="Obra Civil" align="left" />
            <p class="service-lead">
              Ejecutamos proyectos de construcción desde cero con los más altos
              estándares de calidad.
              <strong class="highlight-text"
                >Trae tus planos o usa uno de los nuestros</strong
              > — nos adaptamos a tu visión y presupuesto.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Construcción de viviendas unifamiliares
                y multifamiliares
              </li>
              <li>
                <span class="feature-icon">✓</span> Edificaciones comerciales e institucionales
              </li>
              <li>
                <span class="feature-icon">✓</span> Cimentaciones, estructuras y acabados
                completos
              </li>
              <li>
                <span class="feature-icon">✓</span> Cumplimiento de normativa sismorresistente
                (NSR-10)
              </li>
              <li>
                <span class="feature-icon">✓</span> Obras de infraestructura vial
                y urbanística
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="remodelacion" class="service-detail alt-bg">
      <div class="container">
        <div class="service-detail-inner reverse">
          <div class="service-icon-col">
            <div class="icon-circle">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="16" height="6" x="2" y="2" rx="2"></rect>
                <path
                  d="M10 16v-2a2 2 0 0 1 2-2h8a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"
                ></path>
                <rect width="4" height="12" x="8" y="10" rx="1"></rect>
              </svg>
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle
              title="Mejoramiento de Vivienda y Remodelación"
              align="left"
            />
            <p class="service-lead">
              Transformamos espacios existentes para adaptarlos a tus nuevas
              necesidades y estilo de vida. Dale nueva vida a tu hogar con
              remodelaciones que combinan funcionalidad y estética moderna.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Ampliaciones y mejoramiento de
                espacios existentes
              </li>
              <li>
                <span class="feature-icon">✓</span> Modernización de cocinas, baños
                y fachadas
              </li>
              <li>
                <span class="feature-icon">✓</span> Reparaciones estructurales y reforzamiento
              </li>
              <li>
                <span class="feature-icon">✓</span> Acabados en pisos, pintura y enchapes
              </li>
              <li>
                <span class="feature-icon">✓</span> Asesoría personalizada para transformar
                tu hogar
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="diseno-arquitectonico" class="service-detail">
      <div class="container">
        <div class="service-detail-inner">
          <div class="service-icon-col">
            <div class="icon-circle">
              <svg
                fill="currentColor"
                width="48px"
                height="48px"
                viewBox="0 0 64 64"
                xmlns="http://www.w3.org/2000/svg"
              >
                <g id="b">
                  <path
                    d="M53.5,17h-9.5v-2.5c0-.8271-.6729-1.5-1.5-1.5h-1.5v-1.5c0-.8271-.6729-1.5-1.5-1.5s-1.5,.6729-1.5,1.5v1.5h-1.5c-.8271,0-1.5,.6729-1.5,1.5v2.5H19v-3.3965c0-.2549-.1914-.4688-.4443-.4971-.27-.0293-6.6582-.7188-9.3521,1.6904-.7988,.7139-1.2036,1.623-1.2036,2.7031v29.2373c0,1.0957,.2021,2.0967,.6011,2.9756,.5054,1.1143,1.2388,1.9668,2.1807,2.5342,1.6851,1.6143,5.8179,1.7598,7.2471,1.7598,.2754,0,.4507-.0059,.4883-.0068H53.5c1.3789,0,2.5-1.1211,2.5-2.5V19.5c0-1.3789-1.1211-2.5-2.5-2.5Zm-10.4152,5.8197l6.7062,8.1871,.4102,3.7471-1.252,.9658-8.163-10.0267,2.2986-2.8734Zm-3.5848-2.8197c.5523,0,1,.4477,1,1s-.4477,1-1,1-1-.4478-1-1,.4477-1,1-1Zm-1.2862,5.6931l-8.1635,10.0267-1.251-.9658,.4097-3.7471,6.7062-8.1871,2.2986,2.8734Zm16.7862,25.8069c0,.8271-.6729,1.5-1.5,1.5H18.5v.5l-.0171-.5c-1.4717,.0527-5.6069-.1191-7.0161-1.4805-.3101-.2998-.4609-.6338-.4614-1.0205,.0005-.5244,.1929-.9531,.5884-1.3096,1.4956-1.3457,5.4551-1.2607,6.854-1.1143,.1421,.0146,.2812-.0303,.3867-.126,.1055-.0947,.1655-.2295,.1655-.3711V18h16v3.5c0,.1133,.0391,.2236,.1094,.3125l.1675,.2094-6.9355,8.4664c-.0615,.0742-.0996,.166-.1104,.2617l-.4561,4.1738c-.019,.1738,.0537,.3438,.1914,.4502l.5143,.397-1.3437,2.0007c-.1324,.1969-.1102,.4665,.0654,.6385,.1981,.1941,.516,.1909,.7101-.0072l1.713-1.7483,.1993,.1538c.0908,.0703,.1987,.1045,.3052,.1045,.1455,0,.2896-.0635,.3882-.1846l8.3346-10.2369,.2567,.3209c.0947,.1182,.2383,.1875,.3906,.1875s.2959-.0693,.3906-.1875l.2567-.3209,8.3341,10.2369c.0986,.1211,.2422,.1846,.3877,.1846,.1074,0,.2148-.0342,.3057-.1045l.1996-.154c.0197,.02,1.7133,1.7485,1.7132,1.7484,.4018,.4332,1.1201-.144,.7755-.6313l-1.3436-2.0006,.5146-.3971c.1377-.1064,.21-.2764,.1914-.4502l-.457-4.1738c-.0107-.0957-.0488-.1875-.1104-.2617l-6.9351-8.4664,.1675-.2094c.0703-.0889,.1094-.1992,.1094-.3125v-3.5h9.5c.8271,0,1.5,.6729,1.5,1.5V51.5Z"
                  ></path>
                </g>
              </svg>
            </div>
          </div>
          <div class="service-text-col">
            <SectionTitle title="Diseño Arquitectónico" align="left" />
            <p class="service-lead">
              Creamos espacios funcionales y estéticamente atractivos, adaptados
              al entorno y a tus necesidades. Desde la idea inicial hasta los
              planos definitivos, te acompañamos en todo el proceso creativo.
            </p>
            <ul class="feature-list">
              <li>
                <span class="feature-icon">✓</span> Diseño de planos arquitectónicos
                y estructurales
              </li>
              <li>
                <span class="feature-icon">✓</span> Renders 3D y visualización de
                proyectos
              </li>
              <li>
                <span class="feature-icon">✓</span> Tramitación de licencias de construcción
              </li>
              <li>
                <span class="feature-icon">✓</span> Diseño adaptado al clima del Oriente
                Antioqueño
              </li>
              <li>
                <span class="feature-icon">✓</span> Optimización de espacios y distribución
                funcional
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container">
        <h2 class="cta-text">¿Tienes un proyecto en mente? Hablemos.</h2>
        <a href="/contacto" class="btn btn-primary btn-large"
          >Solicita tu Cotización</a
        >
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Los estilos se mantienen exactamente iguales a tu original */
  .page-header {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }
  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-white);
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-light);
  }

  .service-detail {
    padding: 3rem 1rem;
    scroll-margin-top: 80px;
  }
  .service-detail.alt-bg {
    background-color: var(--color-background);
  }
  .service-detail-inner {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
  }
  .service-detail-inner.reverse {
    flex-direction: row-reverse;
  }

  .icon-circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background-color: var(--color-light);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .service-detail:hover .icon-circle {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .service-lead {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-secondary);
    margin-bottom: 2rem;
  }
  .highlight-text {
    color: var(--color-accent);
    font-weight: 700;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    line-height: 1.6;
  }
  .feature-icon {
    color: var(--color-accent);
    font-weight: 700;
    margin-top: 2px;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight bold;
  }


  .cta-banner {
    padding: 5rem 1rem;
    background-color: var(--color-accent);
    text-align: center;
    color: var(--color-white);
  }
  .cta-text {
    font-size: 2rem;
    margin-bottom: 2rem;
    max-width: 700px;
    margin: 0 auto 2rem;
    color: var(--color-white);
  }

  .btn-large {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    border-radius: 50px;
    background-color: var(--color-white);
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 700;
    border: 2px solid var(--color-white);
  }
  .btn-large:hover {
    background-color: transparent;
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .service-detail-inner,
    .service-detail-inner.reverse {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .feature-list li {
      justify-content: center;
    }
    .cta-text {
      font-size: 1.5rem;
    }
  }
</style>
