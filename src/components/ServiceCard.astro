---
import IconArchitec from "./icon/IconArchitec.astro";
import IconPaintRoller from "./icon/IconPaintRoller.astro";
import IconWall from "./icon/IconWall.astro";

interface Props {
  title: string;
  description: string;
  icon?: "hammer" | "paint-roller" | string;
  link?: string;
}

const { title, description, icon, link = "/servicios" } = Astro.props;
---

<div class="service-card">
  <div class="icon-bar">
    <div class="icon-wrapper">
      {icon === "hammer" && <IconWall size={48} />}
      {icon === "paint-roller" && <IconPaintRoller size={48} />}
      {
        icon !== "hammer" && icon !== "paint-roller" && (
          <IconArchitec size={48} />
        )
      }
    </div>
  </div>

  <div class="card-content">
    <h3 class="service-title">{title}</h3>
    <p class="service-description">{description}</p>
    <a href={link} class="learn-more">Conoce más &rarr;</a>
  </div>
</div>

<style>
  .service-card {
    background-color: var(--color-white);
    /* Quitamos el padding global para que la barra llegue al borde */
    padding: 0;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--color-neutral);
    overflow: hidden; /* Importante para que el fondo del icono respete el border-radius */
  }
  .icon-bar {
    background-color: var(--color-light); /* Color crema de tu paleta */
    display: flex;
    justify-content: center; /* Centra el icono horizontalmente */
    align-items: center; /* Centra el icono verticalmente */
    padding: 1rem 0; /* Ajusta esto para cambiar el alto de la franja */
    width: 100%;
  }
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .icon-wrapper {
    /* Color oscuro de tu paleta para el icono */
    color: var(--color-secondary);
  }
  .card-content {
    padding: 1.5rem 2rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .service-title {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    color: #2b3d41; /* Color oscuro para contraste */
    font-weight: 700;
  }

  .service-description {
    color: #4c5f6b; /* Gris azulado de tu paleta */
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .learn-more {
    color: #ae381e; /* Rojo terracota para el CTA */
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    width: fit-content;
    transition: border-color 0.2s;
  }

  .learn-more:hover {
    border-bottom-color: #ae381e;
  }
</style>
