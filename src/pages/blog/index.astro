---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import PostCard from '../../components/PostCard.astro';
import { sanityClient } from '../../lib/sanity';
import type { Publicacion as Post } from '../../../types/sanity';

const LIMIT = 10;

// Consulta inicial (SSR)
const queryPosts = `{
  "items": *[_type == "publicacion"] | order(fechaPublicacion desc, _id desc) [0...${LIMIT}] {
    _id,
    titulo,
    slug,
    fechaPublicacion,
    imagen,
    extracto
  },
  "total": count(*[_type == "publicacion"])
}`;

const { items: posts, total } = await sanityClient.fetch(queryPosts);
const lastItem = posts[posts.length - 1];
const hasMoreInitial = posts.length < total;
---

<BaseLayout 
  title="Blog | Construcciones Juan Pablo II" 
  description="Noticias, artículos y actualizaciones sobre la Construcciones Juan Pablo II y el mundo de la construcción en el Oriente Antioqueño."
>
  <div class="blog-page">
    <div class="page-header">
      <div class="container">
        <SectionTitle title="Blog y Noticias" align="center" color="white" />
        <p class="page-subtitle">Mantente informado sobre nuestros últimos acontecimientos.</p>
      </div>
    </div>

    <section class="container content-section">
      <div id="posts-grid" class="posts-grid">
        {posts.map((post: Post) => (
          <PostCard post={post} />
        ))}
      </div>

      {posts.length === 0 && (
        <div class="no-posts">
          <p>Próximamente publicaremos noticias y artículos.</p>
        </div>
      )}

      {hasMoreInitial && (
        <div class="pagination-controls">
          <button 
            id="load-more-btn" 
            class="btn btn-secondary load-more-btn"
            data-lastdate={lastItem?.fechaPublicacion}
            data-lastid={lastItem?._id}
            data-totalitems={total}
            data-totalInitial={posts.length}
          >
            Cargar más
          </button>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const btnLoadMore = document.getElementById('load-more-btn') as HTMLButtonElement | null;
  const grid = document.getElementById('posts-grid');

  let lastDateForServer=btnLoadMore?.dataset.lastdate;
  let lastIdForServer=btnLoadMore?.dataset.lastid;

  const totalItems = parseInt(btnLoadMore?.dataset.totalitems || '0', 10);
  const totalInitial = parseInt(btnLoadMore?.dataset.totalinitial || '0', 10);
  let carryingItems = totalInitial;

  const setupPagination = () => {
    if (!btnLoadMore || !grid) return;

    btnLoadMore.addEventListener('click', async () => {
      if (!lastDateForServer || !lastIdForServer) return;

      btnLoadMore.disabled = true;
      btnLoadMore.innerText = 'Cargando...';
      
      try {
        const response = await fetch(`/partials/posts?lastDate=${lastDateForServer}&lastId=${lastIdForServer}`);
        const html = await response.text();

        if (html.trim().length > 0) {
          grid.insertAdjacentHTML('beforeend', html);

          // Leemos los nuevos cursores desde los headers de la respuesta
          lastDateForServer = response.headers.get('x-last-date') || undefined;
          lastIdForServer = response.headers.get('x-last-id')|| undefined;
          const dataLength = parseInt(response.headers.get('x-data-length') || '0', 10);

    
          carryingItems += dataLength;
          
          if (carryingItems >= totalItems) {
            btnLoadMore.closest('.pagination-controls')?.remove();
          }
        } else {
          btnLoadMore.remove();
        }
      } catch (e) {
        console.error("Error en paginación:", e);
      } finally {
        btnLoadMore.disabled = false;
        btnLoadMore.innerText = 'Cargar más';
      }
    });
  };

  setupPagination();
  document.addEventListener('astro:page-load', setupPagination);
</script>

<style>
  .page-header {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-light);
    margin-top: 1rem;
  }
  .content-section { padding: 5rem 1rem; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }
  .pagination-controls { text-align: center; margin-top: 4rem; }
  .load-more-btn { padding: 0.75rem 2.5rem; font-size: 1.1rem; cursor: pointer; }
  .no-posts { text-align: center; padding: 3rem; font-style: italic; }
</style>