---
// PostCard.astro
import ImagePlaceholder from './ImagePlaceholder.astro';
// Asumiendo que tienes tus utilidades en una carpeta lib o utils
import formatDateCustom  from '../lib/formatDateCustom'; 
import { imageUrlFor } from '../lib/imageUrlFor';
interface Props {
  post: any; // O usa tu interfaz 'Publicacion'
}

const { post } = Astro.props;
---

<article class="post-card">
    <div class="image-wrapper">
        {post.imagen ? (
            <img 
                src={imageUrlFor(post.imagen).width(600).height(400).url()} 
                alt={post.titulo}
                loading="lazy" 
            />
        ) : (
            <ImagePlaceholder />
        )}
    </div>
    <div class="post-content">
        <div class="post-meta">
            <span class="date">{formatDateCustom(post.fechaPublicacion)}</span>
        </div>
        <h2 class="post-title">
            <a href={`/blog/${post.slug.current}`}>{post.titulo}</a>
        </h2>
        {post.extracto && <p class="post-excerpt">{post.extracto}</p>}
        <div class="post-footer">
            <a href={`/blog/${post.slug.current}`} class="read-more">
                Leer más &rarr;
            </a>
        </div>
    </div>
</article>

<style>
/* Los estilos se mantienen casi idénticos y son scoped por defecto */
.post-card {
    background-color: var(--color-white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
}

.post-card:hover {
    transform: translateY(-5px);
}

.image-wrapper {
    height: 200px;
    overflow: hidden;
    background-color: var(--color-gray-200);
}

.image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.post-card:hover .image-wrapper img {
    transform: scale(1.05);
}

.post-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.post-meta {
    font-size: 0.85rem;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
}

.post-title {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    line-height: 1.3;
}

.post-title a {
    color: var(--color-primary);
    text-decoration: none;
}

.post-title a:hover {
    color: var(--color-accent);
}

.post-excerpt {
    color: var(--color-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.post-footer {
    margin-top: auto;
}

.read-more {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
}

.read-more:hover {
    text-decoration: underline;
}
</style>