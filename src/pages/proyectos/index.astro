---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { sanityClient } from '../../lib/sanity';
import type { Proyecto } from '../../../types/sanity';
import { imageUrlFor } from '../../lib/imageUrlFor';

const LIMIT = 10;

// Consulta optimizada: Trae los items y el total en una sola petición a Sanity
const queryInitial = `{
  "items": *[_type == "proyecto"] | order(fechaPublicacion desc, _id desc) [0...${LIMIT}] {
    _id,
    title,
    slug,
    location,
    gallery,
    fechaPublicacion
  },
  "total": count(*[_type == "proyecto"])
}`;

const { items: projects, total } = await sanityClient.fetch(queryInitial);
const lastItem = projects[projects.length - 1];

const hasMoreInitial = projects.length < total;

---

<BaseLayout 
  title="Proyectos | Construcciones Juan Pablo II"
  description="Galería de proyectos de construcción y remodelación realizados por Construcciones Juan Pablo II S.A.S."
>
  <div class="projects-page">
    <div class="page-header">
      <div class="container">
        <SectionTitle title="Nuestros Proyectos" color="var(--color-white)" as="h1"/>
        <p class="page-subtitle">Explora nuestros proyectos realizados y nuevos lanzamientos.</p>
      </div>
    </div>

    <section class="container content-section">
      <div id="projects-grid" class="projects-grid">
        {projects.map((project: Proyecto) => (
          <ProjectCard 
            title={project.title} 
            slug={project.slug.current}
            location={project.location}
            imageUrl={project.gallery && project.gallery[0] ? imageUrlFor(project.gallery[0]).width(600).height(400).url() : undefined}
          />
        ))}
      </div>

      {projects.length === 0 && (
        <div class="no-projects">
          <p>Próximamente encontrarás todos nuestros proyectos aquí.</p>
        </div>
      )}

  
      {hasMoreInitial && (
        <div class="pagination-controls">
          <button 
            id="load-more-btn" 
            class="btn btn-secondary load-more-btn"
            data-lastdate={lastItem?.fechaPublicacion}
            data-lastid={lastItem?._id}
            data-totalitems={total}
            data-totalInitial={projects.length}
          >
            Cargar más
          </button>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const btnLoadMore = document.getElementById('load-more-btn') as HTMLButtonElement | null;
  const grid = document.getElementById('projects-grid');

  let lastDateForServer=btnLoadMore?.dataset.lastdate;
  let lastIdForServer=btnLoadMore?.dataset.lastid;

  const totalItems = parseInt(btnLoadMore?.dataset.totalitems || '0', 10);
  const totalInitial = parseInt(btnLoadMore?.dataset.totalinitial || '0', 10);
  let carryingItems = totalInitial;

  const setupPagination = () => {
    
    if (!btnLoadMore || !grid) return;

    btnLoadMore.addEventListener('click', async () => {

      if (!lastDateForServer || !lastIdForServer) return;

      btnLoadMore.disabled = true;
      btnLoadMore.innerText = 'Cargando...';

      try {
        const response = await fetch(`/partials/projects?lastDate=${lastDateForServer}&lastId=${lastIdForServer}`);
        const html = await response.text();

        if (html.trim().length > 0) {
          grid.insertAdjacentHTML('beforeend', html);

          lastDateForServer = response.headers.get('x-last-date') || undefined;
          lastIdForServer = response.headers.get('x-last-id')|| undefined;
          const dataLength = parseInt(response.headers.get('x-data-length') || '0', 10);

          carryingItems += dataLength;
          
          if (carryingItems >= totalItems) {
            btnLoadMore.closest('.pagination-controls')?.remove();
          }
        } else {
          btnLoadMore.closest('.pagination-controls')?.remove();
        }
      } catch (e) {
        console.error('Error cargando más proyectos:', e);
      } finally {
        if (document.body.contains(btnLoadMore)) {
          btnLoadMore.disabled = false;
          btnLoadMore.innerText = 'Cargar más';
        }
      }
    });
  };

  setupPagination();
  document.addEventListener('astro:page-load', setupPagination);
</script>

<style>
  .page-header {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-light);
    margin-top: 1rem;
  }
  .content-section { padding: 5rem 1rem; }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }
  .pagination-controls { text-align: center; margin-top: 4rem; }
  .load-more-btn { padding: 0.75rem 2.5rem; font-size: 1.1rem; }
  .no-projects { text-align: center; padding: 3rem; font-style: italic; }
</style>